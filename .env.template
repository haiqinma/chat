# Chat 运行期配置模板
#
# 这个文件只用于部署期和服务运行期变量。
# 发包完成后，仍然可以继续修改这个文件。
#
# 运行规则：
# 1. 服务端运行期配置
#    - Node 服务启动时从 `.env` 读取
#    - 修改后需要重启服务
# 2. 前端公开运行期配置
#    - 也在 Node 服务启动时从 `.env` 读取
#    - 会通过 `meta[name="runtime-config"]` 和 `/api/config` 下发到浏览器
#    - 修改后需要重启服务，并刷新页面
#
# 构建/发包变量已经移动到 `.env.build.template`。
#
# 本文件中的布尔开关统一推荐使用：
# - `0`：关闭
# - `1`：开启
# 同时兼容 `true` / `false` 写法，但推荐统一使用 `0` / `1`。

################################################################################
# 服务端运行期配置 - 私有 / 仅后端使用
# 生效方式：需要重启服务
# 浏览器是否可见：否
################################################################################

# OpenAI / 兼容上游
OPENAI_API_KEY=
BASE_URL=
OPENAI_ORG_ID=

# 可选：访问码开关。原始 `CODE` 值不会公开。
# 前端只能看到一个派生布尔值：当前是否需要访问码。
CODE=

# 可选：代理 / 部署标记
PROXY_URL=
VERCEL=0

# 各模型服务商配置
STABILITY_URL=
STABILITY_API_KEY=

AZURE_URL=
AZURE_API_KEY=
AZURE_API_VERSION=

GOOGLE_API_KEY=
GOOGLE_URL=

ANTHROPIC_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_API_VERSION=

BAIDU_URL=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

VOLCENGINE_URL=
VOLCENGINE_API_KEY=

ALIBABA_URL=
ALIBABA_API_KEY=

TENCENT_URL=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

MOONSHOT_URL=
MOONSHOT_API_KEY=

IFLYTEK_URL=
IFLYTEK_API_KEY=
IFLYTEK_API_SECRET=

DEEPSEEK_URL=
DEEPSEEK_API_KEY=

XAI_URL=
XAI_API_KEY=

CHATGLM_URL=
CHATGLM_API_KEY=

SILICONFLOW_URL=
SILICONFLOW_API_KEY=

AI302_URL=
AI302_API_KEY=

# 统计 / 基础设施
GTM_ID=
GA_ID=

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_KV_API_KEY=
CLOUDFLARE_KV_TTL=

# `/api/webdav/[...path]` 使用的本地 WebDAV 访问开关
ALLOW_LOCAL_WEBDAV=0

################################################################################
# 前端公开运行期配置 - 浏览器可见
# 生效方式：重启服务 + 刷新页面
# 浏览器是否可见：是
################################################################################

# 用于预处理用户输入的默认模板
DEFAULT_INPUT_TEMPLATE=

# 界面 / 模型能力开关
HIDE_USER_API_KEY=0
DISABLE_GPT4=0
ENABLE_BALANCE_QUERY=0
DISABLE_FAST_LINK=0
CUSTOM_MODELS=
DEFAULT_MODEL=
VISION_MODELS=
ENABLE_MCP=0

# Router / 后端地址
ROUTER_BACKEND_URL=http://127.0.0.1:3011

# WebDAV 公开地址组成部分
# 如果 `WEBDAV_BACKEND_BASE_URL` 本身已经带 path，服务端会尽量自动拆成
# `base + prefix`。
WEBDAV_BACKEND_BASE_URL=http://127.0.0.1:6065
WEBDAV_BACKEND_PREFIX=/dav

# 中心化 UCAN 认证
CENTRAL_UCAN_AUTH_BASE_URL=http://127.0.0.1:8100
CENTRAL_UCAN_APP_ID=

# 可选值：`auto` | `wallet` | `central`
UCAN_LOGIN_FORCE_MODE=auto

################################################################################
# 不属于应用配置层的进程 / 部署变量
# 生效方式取决于你的进程管理方式
################################################################################

# `npm run start` 或部署脚本常用的运行端口
PORT=3020
